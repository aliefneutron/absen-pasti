rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // HELPERS
    // -------------------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // USERS COLLECTION
    // -------------------------------------------------------------------------
    
    match /users/{userId} {
      allow list: if isSignedIn();
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if (isSignedIn() && isOwner(userId)) || isAdmin();
      allow update, delete: if isAdmin() || (isSignedIn() && isOwner(userId) && !incoming().diff(existing()).affectedKeys().hasAny(['role', 'isAdmin']));
    }

    // -------------------------------------------------------------------------
    // ATTENDANCE COLLECTION
    // -------------------------------------------------------------------------
    
    match /attendance/{recordId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() && 
                      incoming().userId == request.auth.uid &&
                      incoming().timestamp == request.time &&
                      incoming().keys().hasAll(['userId', 'userName', 'userEmail', 'timestamp', 'date', 'location', 'isWithinRange', 'isLate', 'selfieUrl']);
      
      allow update, delete: if false; // Attendance records are immutable
    }

    // -------------------------------------------------------------------------
    // SETTINGS COLLECTION
    // -------------------------------------------------------------------------
    
    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
